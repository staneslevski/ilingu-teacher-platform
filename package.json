{
  "name": "ilingu-admin-platform",
  "version": "1.3.0",
  "private": true,
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^1.2.12",
    "@fortawesome/free-solid-svg-icons": "^5.3.1",
    "@fortawesome/react-fontawesome": "^0.1.2",
    "@material-ui/core": "1.4.3",
    "@material-ui/icons": "2.0.1",
    "@sentry/browser": "^5.2.0",
    "@types/googlemaps": "3.30.11",
    "@types/markerclustererplus": "2.1.33",
    "ajv": "6.5.2",
    "aws-amplify": "^1.1.1",
    "chartist": "0.10.1",
    "clean": "^4.0.2",
    "cloudinary-react": "^1.1.0",
    "connected-react-router": "^6.0.0",
    "draft-js": "^0.10.5",
    "draft-js-export-html": "^1.2.0",
    "fullcalendar-reactwrapper": "^1.0.7",
    "history": "4.7.2",
    "i": "^0.3.6",
    "lodash": "latest",
    "mdi-material-ui": "^5.4.0",
    "moment": "2.22.2",
    "moment-timezone": "^0.5.23",
    "node-sass-chokidar": "1.3.3",
    "npm": "^6.4.1",
    "npm-run-all": "4.1.3",
    "perfect-scrollbar": "1.4.0",
    "react": "^16.5.2",
    "react-big-calendar": "0.19.2",
    "react-bootstrap-sweetalert": "4.4.1",
    "react-chartist": "0.13.1",
    "react-cookie": "^3.0.8",
    "react-datetime": "2.15.0",
    "react-dom": "^16.4.1",
    "react-draft-wysiwyg": "^1.12.13",
    "react-ga": "^2.5.3",
    "react-google-maps": "9.4.5",
    "react-jvectormap": "0.0.3",
    "react-nouislider": "2.0.1",
    "react-redux": "^6.0.0",
    "react-router-dom": "4.3.1",
    "react-scripts": "^2.1.8",
    "react-select": "^2.2.0",
    "react-swipeable-views": "0.12.15",
    "react-table": "6.8.6",
    "react-tagsinput": "3.19.0",
    "react-window": "^1.5.0",
    "redux": "^4.0.1",
    "redux-thunk": "^2.3.0"
  },
  "scripts": {
    "build-css": "node-sass-chokidar --include-path ./src --include-path ./node_modules src/ -o src/",
    "watch-css": "npm run build-css && node-sass-chokidar --include-path ./src --include-path ./node_modules src/ -o src/ --watch --recursive",
    "start-js": "react-scripts start",
    "start:dev": "HOST=ilingu.toast PORT=3000 REACT_APP_STAGE=dev npm-run-all -p watch-css start-js",
    "start:test": "HOST=localhost PORT=3000 REACT_APP_STAGE=testing npm-run-all -p watch-css start-js",
    "build:stagingstaging": "REACT_APP_STAGE=staging npm run build-css && react-scripts build",
    "build:staging": "REACT_APP_STAGE=staging npm run build:stagingstaging",
    "build": "REACT_APP_STAGE=production npm run build-css && react-scripts build",
    "build:production": "REACT_APP_STAGE=production npm run build",
    "build:test": "REACT_APP_STAGE=testing npm run build-css && react-scripts build",
    "test": "react-scripts test --env=jsdom",
    "eject": "react-scripts eject",
    "lint:check": "eslint . --ext=js,jsx;  exit 0",
    "lint:fix": "eslint . --ext=js,jsx --fix;  exit 0",
    "analyze": "source-map-explorer build/static/js/main.*",
    "cypress:open": "BABEL_ENV=test cypress open",
    "install:clean": "rm -rf node_modules/ && rm -rf package-lock.json && npm install"
  },
  "optionalDependencies": {
    "eslint-config-prettier": "^2.9.0",
    "eslint-plugin-prettier": "^2.6.2",
    "eslint-plugin-react": "^7.13.0",
    "prettier": "^1.13.7"
  },
  "browserslist": [
    ">0.2%",
    "not dead",
    "not ie <= 11",
    "not op_mini all"
  ],
  "devDependencies": {
    "@babel/core": "^7.4.4",
    "@babel/register": "^7.4.4",
    "babel-preset-react-app": "^8.0.0",
    "cypress": "^3.3.1",
    "mailgun.js": "^2.0.1",
    "prop-types": "latest",
    "request-promise": "^4.2.4",
    "source-map-explorer": "^1.6.0"
  }
}
